---
export const prerender = false;

import HomePage from '../components/home/HomePage.astro';
import Layout from '../layouts/Layout.astro';
import { toAbsoluteUrl } from '../lib/absolute-url';
import { getIframeEmbed } from '../lib/embed-iframe';
import { loadSiteLive } from '../lib/load-live-content';
import { prepareVideoLazyEmbed } from '../lib/prepare-home-video';

const site = await loadSiteLive();

const ogImageUrl = toAbsoluteUrl('/images/n4n4_artwork.jpg', Astro.site);
const ogImageAlt =
  'N4N4 artwork: grainy, low-fi image of a figure with head in hand, with red distorted text reading N4N4.';
const album = getIframeEmbed(site.albumIframe);
const videoEmbed = getIframeEmbed(site.video.videoIframe);

const bgUrl = site.backgroundPicture?.trim() ?? '';
const logoUrl = site.logo?.trim() ?? '';
const videoThumb = site.video.thumbnail?.trim() ?? '';
const press = site.pressText?.trim() ?? '';

const { videoLazySrc, videoLazyHtmlB64, useVideoPoster } = prepareVideoLazyEmbed(
  videoThumb,
  videoEmbed,
);

const heroBgStyle = bgUrl
  ? { backgroundImage: `url(${JSON.stringify(bgUrl)})` }
  : undefined;
---

<Layout
  title={site.title}
  description={site.description}
  image={ogImageUrl}
  imageAlt={ogImageAlt}
>
  <HomePage
    heroBgStyle={heroBgStyle}
    logoUrl={logoUrl}
    siteTitle={site.title}
    press={press}
    album={album}
    videoThumb={videoThumb}
    videoEmbed={videoEmbed}
    useVideoPoster={useVideoPoster}
    videoLazySrc={videoLazySrc}
    videoLazyHtmlB64={videoLazyHtmlB64}
    contactHtml={site.contactHtml}
  />
</Layout>
