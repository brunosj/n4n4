---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { toAbsoluteUrl } from '../lib/absolute-url';
import { extractIframeSrc, getIframeEmbed } from '../lib/embed-iframe';
import { loadSiteLive } from '../lib/load-live-content';

const site = await loadSiteLive();

const ogImageUrl = toAbsoluteUrl('/images/n4n4_artwork.jpg', Astro.site);
const ogImageAlt =
  'N4N4 artwork: grainy, low-fi image of a figure with head in hand, with red distorted text reading N4N4.';
const album = getIframeEmbed(site.albumIframe);
const videoEmbed = getIframeEmbed(site.video.videoIframe);

const bgUrl = site.backgroundPicture?.trim() ?? '';
const logoUrl = site.logo?.trim() ?? '';
const videoThumb = site.video.thumbnail?.trim() ?? '';
const press = site.pressText?.trim() ?? '';

/** Lazy-load video only after click when thumbnail + embed are both set. */
let videoLazySrc: string | null = null;
let videoLazyHtmlB64: string | null = null;
if (videoEmbed) {
  if (videoEmbed.kind === 'src') {
    videoLazySrc = videoEmbed.src;
  } else {
    const extracted = extractIframeSrc(videoEmbed.html);
    if (extracted) {
      videoLazySrc = extracted;
    } else {
      videoLazyHtmlB64 = Buffer.from(videoEmbed.html, 'utf8').toString('base64');
    }
  }
}
const useVideoPoster = Boolean(
  videoThumb && videoEmbed && (videoLazySrc || videoLazyHtmlB64),
);

const heroBgStyle = bgUrl
  ? { backgroundImage: `url(${JSON.stringify(bgUrl)})` }
  : undefined;
---

<Layout
  title={site.title}
  description={site.description}
  image={ogImageUrl}
  imageAlt={ogImageAlt}
>
  <div class="home">
    <section class="home__stage" aria-label="Introduction" style={heroBgStyle}>
      {
        logoUrl ? (
          <div class="home__logo-wrap">
            <img
              class="home__logo"
              src={logoUrl}
              alt={site.title}
              width="800"
              height="400"
              loading="eager"
              decoding="async"
            />
          </div>
        ) : null
      }
      <div class="home__title-row">
        <h1 class="home__title">{site.title}</h1>
        <!-- <p class="home__description">{site.description}</p> -->
      </div>
      {
        press ? (
          <div class="home__press-wrap">
            <div class="home__press">{press}</div>
          </div>
        ) : null
      }
        <div class="home__foreground">
          {
            album?.kind === 'src' ? (
              <div class="home__album-wrap">
                <iframe
                  class="home__album"
                  src={album.src}
                  title="Album player"
                  width="100%"
                  height="344"
                  loading="lazy"
                  allow="encrypted-media; fullscreen; autoplay; clipboard-write"
                  referrerpolicy="strict-origin-when-cross-origin"
                />
              </div>
            ) : album?.kind === 'html' ? (
              <div class="home__album-html" set:html={album.html} />
            ) : null
          }
        </div>
        {
          videoThumb || videoEmbed ? (
            <section class="home__video-stack" aria-label="Video">
              <div class="home__video-shell">
                <div class="home__video">
                  {useVideoPoster ? (
                    <div
                      class="home__video-lazy"
                      data-video-src={videoLazySrc ?? undefined}
                      data-video-html={videoLazyHtmlB64 ?? undefined}
                    >
                      <button type="button" class="home__video-poster" aria-label="Play video">
                        <img
                          class="home__video-poster-img"
                          src={videoThumb}
                          alt=""
                          width="1280"
                          height="720"
                          loading="lazy"
                          decoding="async"
                        />
                        <span class="home__video-poster-play" aria-hidden="true">
                          <img src="/play.svg" alt="" width="80" height="80" class="" />
                        </span>
                      </button>
                      <div class="home__video-slot home__video-wrap" hidden></div>
                    </div>
                  ) : videoEmbed?.kind === 'src' ? (
                    <div class="home__video-wrap">
                      <iframe
                        class="home__video-iframe"
                        src={videoEmbed.src}
                        title="Video"
                        width="100%"
                        height="344"
                        loading="lazy"
                        allow="encrypted-media; fullscreen; autoplay; clipboard-write; picture-in-picture"
                        referrerpolicy="strict-origin-when-cross-origin"
                      />
                    </div>
                  ) : videoEmbed?.kind === 'html' ? (
                    <div class="home__video-html" set:html={videoEmbed.html} />
                  ) : videoThumb ? (
                    <img
                      class="home__video-thumb"
                      src={videoThumb}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  ) : null}
                </div>
              </div>
            </section>
          ) : null
        }
    </section>

    <section class="home__contact" id="contact" aria-labelledby="contact-heading">
      <div class="home__contact-inner">
        <!-- <h2 id="contact-heading" class="home__contact-heading">Contact</h2> -->
        <div class="home__contact-prose" set:html={site.contactHtml} />
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      function b64ToUtf8(b64) {
        const bin = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        return new TextDecoder('utf-8').decode(bytes);
      }

      function init() {
        document.querySelectorAll('.home__video-lazy').forEach((root) => {
          const poster = root.querySelector('.home__video-poster');
          const slot = root.querySelector('.home__video-slot');
          if (!poster || !slot) return;

          function activate() {
            if (root.getAttribute('data-video-activated') === 'true') return;
            root.setAttribute('data-video-activated', 'true');
            poster.remove();
            slot.removeAttribute('hidden');
            const src = root.getAttribute('data-video-src');
            const htmlB64 = root.getAttribute('data-video-html');
            if (src) {
              const ifr = document.createElement('iframe');
              ifr.src = src;
              ifr.title = 'Video';
              ifr.width = '100%';
              ifr.height = '344';
              ifr.setAttribute(
                'allow',
                'encrypted-media; fullscreen; autoplay; clipboard-write; picture-in-picture',
              );
              ifr.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
              ifr.className = 'home__video-iframe';
              ifr.loading = 'lazy';
              slot.appendChild(ifr);
            } else if (htmlB64) {
              slot.innerHTML = b64ToUtf8(htmlB64);
            }
          }

          poster.addEventListener('click', activate);
          poster.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              activate();
            }
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</Layout>

<style>
  .home {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .home__stage {
    position: relative;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    min-height: 100dvh;
    min-height: 100vh;
    background-color: var(--color-bg);
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
  }

  /* Same width + horizontal padding as `.home__press-wrap` so title and press line up. */
  .home__title-row {
    position: relative;
    z-index: 0;
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(var(--space-sm), 4vw, var(--space-xl)) var(--space-md);
    box-sizing: border-box;
    text-align: left;
    min-width: 0;
  }

  .home__foreground {
    position: relative;
    z-index: 0;
    width: 100%;
    max-width: min(42rem, 100%);
    min-width: 0;
    margin: 0 auto;
    padding: 0 clamp(var(--space-sm), 4vw, var(--space-xl));
    box-sizing: border-box;
    text-align: left;
  }

  .home__stage:has(.home__video-stack) .home__album-wrap,
  .home__stage:has(.home__video-stack) .home__album-html {
    margin-bottom: 0;
  }

  .home__video-stack {
    margin-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .home__logo-wrap {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin-bottom: var(--space-xl);
    padding: 0 clamp(var(--space-sm), 4vw, var(--space-md));
    box-sizing: border-box;
  }

  .home__logo {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    width: min(50vw, 100%);
    height: auto;
    object-fit: contain;
  }

  .home__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.75rem);
    font-weight: 400;
    margin: 0 0 var(--space-md);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #fff;
  }

  .home__description {
    margin: 0 0 var(--space-lg);
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    line-height: 1.55;
    color: var(--color-text-muted);
    text-wrap: balance;
  }

  .home__press-wrap {
    width: 100%;
    max-width: 72rem;
    min-width: 0;
    margin: 0 auto var(--space-3xl);
    padding: var(--space-lg) clamp(var(--space-sm), 4vw, var(--space-xl));
    box-sizing: border-box;
    /* Light blue-gray, opaque enough for white type over the photo */
    background: rgba(100, 118, 142, 0.55);
    border-radius: 4px;
  }

  .home__press {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.4vw, 1.65rem);
    line-height: 1.25;
    white-space: pre-line;
    text-align: left;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
  }

  .home__album-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 0 auto var(--space-xl);
    border: var(--border-strong);
    border-radius: 24px;
    /* Do not clip: provider may need more than 344px; iframe scrollbars show there is more content. */
    overflow: visible;
  }

  .home__album {
    display: block;
    width: 100%;
    max-width: 100%;
    border: 0;
    border-radius: 24px;
  }

  .home__album-html {
    margin: 0 auto var(--space-xl);
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: visible;
    border-radius: 24px;
  }

  .home__album-html :global(iframe) {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    border: 0;
  }

  /* Same max-width + horizontal padding as `.home__press-wrap`. */
  .home__video-shell {
    width: 100%;
    max-width: 72rem;
    min-width: 0;
    margin: 0 auto;
    padding: 0 clamp(var(--space-sm), 4vw, var(--space-xl));
    box-sizing: border-box;
  }

  .home__video {
    margin: 0;
    padding: 0;
    text-align: left;
  }

  .home__video-thumb {
    display: block;
    width: 100%;
    height: auto;
    max-height: none;
    object-fit: contain;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
  }

  .home__video-lazy {
    width: 100%;
  }

  .home__video-poster {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    cursor: pointer;
    font: inherit;
    color: inherit;
    background: #000;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .home__video-poster:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  /* Natural height — no max-height crop; letterboxing uses poster chrome (#000). */
  .home__video-poster-img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    max-height: none;
    object-fit: contain;
  }

  .home__video-poster-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .home__video-poster:hover .home__video-poster-play,
  .home__video-poster:focus-visible .home__video-poster-play {
    opacity: 1;
  }

  .home__video-poster-play img {
    width: min(18vw, 5rem);
    height: auto;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.45));
  }

  .home__video-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    overflow: visible;
    background: #000;
  }

  .home__video-iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    border: 0;
    border-radius: 12px;
  }

  .home__video-html {
    margin: 0;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: visible;
    border-radius: 12px;
  }

  .home__video-html :global(iframe) {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    border: 0;
  }

  .home__contact {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    background: rgb(255, 0, 0);
    color: #fff;
    border-top: none;
    padding: 0;
    text-align: left;
  }

  .home__contact-inner {
    width: 100%;
    max-width: none;
    min-width: 0;
    margin: 0;
    padding: var(--space-xl) clamp(var(--space-sm), 4vw, var(--space-xl));
    box-sizing: border-box;
  }

  .home__contact-heading {
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 11vw, 6.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0 0 var(--space-lg);
    padding: 0 0 var(--space-md);
    border-bottom: 2px solid rgba(255, 255, 255, 0.45);
    color: #fff;
    text-align: left;
  }

  .home__contact-prose {
    font-family: var(--font-body);
    font-size: clamp(2.65rem, 7.5vw, 5rem);
    line-height: 1.12;
    text-align: left;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .home__contact-prose :global(p) {
    margin: 0 0 var(--space-md);
  }

  .home__contact-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .home__contact-prose :global(ul),
  .home__contact-prose :global(ol) {
    margin: 0 0 var(--space-md);
    padding-left: 1.5rem;
    line-height: 1.12;
  }

  .home__contact-prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .home__contact-prose :global(a) {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.15em;
    cursor: pointer;
  }

  .home__contact-prose :global(a:hover) {
    color: #ffe0e0;
  }

  .home__contact-prose :global(h2),
  .home__contact-prose :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(2.85rem, 7vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: var(--space-lg) 0 var(--space-sm);
    color: #fff;
    text-align: left;
  }

  .home__contact-prose :global(h2:first-child),
  .home__contact-prose :global(h3:first-child) {
    margin-top: 0;
  }

  .home__contact-prose :global(img) {
    max-width: 100%;
    height: auto;
  }

  .home__contact-prose :global(pre),
  .home__contact-prose :global(code) {
    overflow-x: auto;
    max-width: 100%;
  }

  @media (max-width: 40rem) {
    .home__logo {
      width: min(88vw, 100%);
    }

    .home__title-row {
      padding-bottom: var(--space-xs);
    }

    .home__title {
      font-size: clamp(1.35rem, 7vw, 2.75rem);
      margin-bottom: var(--space-sm);
    }

    .home__press-wrap {
      margin-bottom: var(--space-xl);
    }

    .home__press {
      font-size: clamp(1rem, 4.2vw, 1.65rem);
    }

    .home__album-wrap,
    .home__album-html {
      margin-bottom: var(--space-xl);
    }

    .home__video-stack {
      margin-top: var(--space-xl);
      padding-bottom: var(--space-2xl);
    }

    .home__contact-inner {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-lg);
    }

    .home__contact-prose {
      font-size: clamp(1rem, 4.6vw, 2.5rem);
      line-height: 1.2;
    }

    .home__contact-prose :global(h2),
    .home__contact-prose :global(h3) {
      font-size: clamp(1.25rem, 5.2vw, 3rem);
    }

    .home__contact-prose :global(p) {
      margin-bottom: var(--space-sm);
    }
  }
</style>
